# Copy to .env for local development — never commit .env
GCP_PROJECT_ID=motamaze-dev
ENVIRONMENT=dev
BQ_DATASET=motamaze_analytics
LOG_LEVEL=debug
JWT_ISSUER=https://api.motamaze.com
JWKS_URL=https://api.motamaze.com/.well-known/jwks.json

# Auth — Google OAuth (GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Auth — Sign in with Apple (native iOS; aud in identity_token = app bundle ID)
APPLE_BUNDLE_ID=com.ingeniouscruciblestudios.motamaze

# Payments — App Store Server Library (signed transaction / ASSN v2 verification)
APPLE_ENVIRONMENT=Sandbox
APPLE_APP_APPLE_ID=

# JWT signing — Secret Manager (T-120)
JWT_KEY_ID=motamaze-key-v1
JWT_SECRET_NAME=jwt-private-key

# Social — Tenjin tracking link for share_create (T-311, Decision L Option A)
# Static link from Tenjin dashboard (organic/referral channel) — not an API key.
# Empty = falls back to a direct URL with no attribution.
TENJIN_SHARE_TRACKING_LINK=
