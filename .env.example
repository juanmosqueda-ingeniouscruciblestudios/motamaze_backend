# Copy to .env for local development — never commit .env
GCP_PROJECT_ID=motamaze-dev
ENVIRONMENT=dev
BQ_DATASET=motamaze_analytics
LOG_LEVEL=debug
JWT_ISSUER=https://api.motamaze.com
JWKS_URL=https://api.motamaze.com/.well-known/jwks.json

# Injected via Secret Manager in Cloud Run — set manually for local dev only
JWT_PRIVATE_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
